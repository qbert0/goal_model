istar SmartDelivery

actor Customer {
    goal FastDelivery {
        description = "Fast delivery"
    }

    goal DeliveryTracking {
        description = "Track order"
    }
}

agent DeliverySystem {
    task AssignDriver &> FastDelivery {
        description = "Assign a driver"
    }

    task RouteOptimization &> FastDelivery, +> FastDelivery {
        description = "Optimize route"
    }

    resource DriverDatabase <> AssignDriver {
        description = "Driver database"
    }

    quality Reliability => DriverDatabase {
        description = "Reliability"
    }
}

role Driver {
    task DeliverOrder {
        description = "Deliver order"
    }
}

dependency Dep1 {
    depender Customer
    dependee DeliverySystem
    dependum goal OrderAccepted {
        description = "Order accepted"
    }
}
